# Copy this file to .env and fill in the values before running compose.
# NEVER commit .env — it is in .gitignore.

# -----------------------------------------------------------------------
# REQUIRED — compose will refuse to start if these are unset or empty
# -----------------------------------------------------------------------

# Generate with: openssl rand -hex 32
PENPOT_SECRET_KEY=

# Use a strong random password
PENPOT_DATABASE_PASSWORD=

# -----------------------------------------------------------------------
# OPTIONAL — sensible defaults shown; override as needed
# -----------------------------------------------------------------------

PENPOT_DATABASE_USERNAME=penpot
PENPOT_DATABASE_NAME=penpot

# Public-facing base URL (include port if not 80/443)
PENPOT_PUBLIC_URI=http://localhost:9001

# SMTP — required for email verification if you re-enable it
PENPOT_SMTP_HOST=
PENPOT_SMTP_PORT=587
PENPOT_SMTP_USERNAME=
PENPOT_SMTP_PASSWORD=
PENPOT_SMTP_TLS=true
PENPOT_SMTP_DEFAULT_REPLY_TO=no-reply@example.com
PENPOT_SMTP_DEFAULT_FROM=Penpot <no-reply@example.com>

# Storage — defaults to local filesystem inside the container
# Switch to AWS S3 or compatible (MinIO) for production
# PENPOT_STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# PENPOT_STORAGE_S3_BUCKET=
# PENPOT_STORAGE_S3_REGION=us-east-1
